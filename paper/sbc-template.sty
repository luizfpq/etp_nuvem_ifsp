% sbc-template.sty - Estilo SBC simplificado
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{sbc-template}[2024/01/01 SBC Template]

\RequirePackage[a4paper,top=3cm,bottom=2cm,left=3cm,right=2cm]{geometry}
\RequirePackage{times}

% Titulo
\renewcommand{\maketitle}{%
  \begin{center}
    {\Large\bfseries\@title\par}
    \vskip 1em
    {\large\@author\par}
  \end{center}
  \vskip 1em
}

% Instituição
\newcommand{\inst}[1]{\textsuperscript{#1}}
\newcommand{\address}[1]{\newcommand{\@address}{#1}}
\let\@address\@empty

% Ambiente resumo
\renewenvironment{abstract}{%
  \begin{center}\textbf{Abstract}\end{center}
  \begin{quotation}\small
}{%
  \end{quotation}
}

\newenvironment{resumo}{%
  \begin{center}\textbf{Resumo}\end{center}
  \begin{quotation}\small
}{%
  \end{quotation}
}
